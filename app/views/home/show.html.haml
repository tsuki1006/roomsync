.app_top_page_container

  = render 'common/app_top_title'

  .white_container.app_top_action
    = link_to '新規登録', new_user_registration_path, class: 'sign_up_button'
    .or_line
      .line
      %span.or または
      .line
    = link_to 'ログイン', new_user_session_path, class: 'sign_in_button'

    .document_agreement
      %p
        アカウント作成により、
        = link_to '利用規約', terms_of_service_path
        および
        = link_to 'プライバシーポリシー', privacy_policy_path
        に同意したものとみなします

  .tips.app_top_points
    %ul
      %li
        %div
          %span.point_icon ✨
        %div
          .point_title 学習室の利用予定を可視化
          %p.point_message カレンダーで誰がいつ学習するか一目で分かる
      %li
        %div
          %span.point_icon 🤝
        %div
          .point_title 簡単アクションで予定に参加
          %p.point_message 「一緒に参加」ボタンをクリックするだけ
