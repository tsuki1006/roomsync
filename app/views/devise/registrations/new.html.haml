.app_top_page_container

  = render 'common/app_top_title'

  .white_container.authentication_form_container
    = render 'common/authentication_tab'

    = render "devise/shared/error_messages", resource: resource

    .form_container
      = form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f|

        .form_contents
          .form_item
            .form_label= f.label :email
            %div= f.email_field :email, autofocus: true, autocomplete: "email", class: 'form_input', placeholder: 'example@email.com'

          .form_item
            .form_label= f.label :password
            %div= f.password_field :password, autocomplete: "new-password", class: 'form_input', placeholder: '6文字以上'

          .form_item
            .form_label= f.label :password_confirmation
            %div= f.password_field :password_confirmation, autocomplete: "new-password", class: 'form_input', placeholder: '同じパスワードを入力'

        .form_action
          = f.submit 'アカウントを作成', class: 'form_button authentication_form_button'

        .document_agreement.authentication_form_document_agreement
          %p
            アカウント作成により、
            = link_to '利用規約', terms_of_service_path
            および
            = link_to 'プライバシーポリシー', privacy_policy_path
            に同意したものとみなします
