.form_error
  %ul
    - schedule.errors.full_messages.each do |message|
      %li.form_error_message= message

.white_container.form_container.schedule_form_container
  = form_with(model: [ room, schedule ], local: true) do |f|

    .form_contents.schedule_form_contents

      .form_item
        .form_label
          = f.label :start_time, '開始日時'
          %span.required *
        %div= f.datetime_field :start_time, class: 'form_datetime', min: current_time_15min_rounded, step: 900, value: start_time_auto_fill(schedule)
        %p.form_comment ※15分単位で入力してください

      .form_item
        .form_label
          = f.label :end_time, '終了日時'
          %span.required *
        %div= f.datetime_field :end_time, class: 'form_datetime', min: current_time_15min_rounded, step: 900, value: end_time_auto_fill(schedule)
        %p.form_comment ※15分単位で入力してください

      .form_item
        .form_label
          = f.label :status, '学習スタイル'
          %span.required *
        %div= f.select :status, Schedule.statuses.map { |k, v| [ I18n.t("enum.status.#{k}"), k ] },{}, class: 'form_select'

      .form_item
        .form_label= f.label :comment, '一言コメント（任意）'
        %div= f.text_area :comment, class: 'form_textarea', placeholder: '例：学習内容など'

    .form_action.schedule_form_button
      = link_to 'キャンセル', room_path(room), class: 'schedule_form_button_cancel'
      - button_label = schedule.new_record? ? '予定を作成する' : '予定を更新する'
      = f.submit button_label, class: 'form_button'

.tips
  .tips_title 💡 Tips
  %p.tips_message 時刻はキーボードの上下キーでも簡単に調整できます
